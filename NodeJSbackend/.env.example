# MongoDB Atlas Connection (database: Agricult)
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/Agricult?appName=Smart-Agriculture

# Frontend URL (for CORS whitelist + email links)
FRONTEND_URL=http://localhost:3000

# Python ML Server URL (for CORS whitelist)
MLSERVER_URL=http://localhost:8000

# Server port
PORT=5000

# JWT token signing secret (backend_token)
TOKEN_SECRET_KEY=your_jwt_secret_here

# NextAuth shared secret (must match frontend AUTH_SECRET)
AUTH_SECRET=your_nextauth_secret_here

# ── Email (verification + approval notifications) ──────────────
# Gmail account + app password used to send transactional email.
GMAIL_USER=your_gmail_address@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password

# ── RBAC bootstrap ────────────────────────────────────────────
# This email is auto-granted the "owner" role on registration and
# skips admin approval, so there is always a way into the admin panel.
OWNER_EMAIL=owner@example.com
