# =============================================================
# backend/env.example.txt
#
# HOW TO USE:
#   Copy/rename this file to exactly:  .env
#   Fill in your real values below.
#   The .env file is in .gitignore — NEVER committed to Git.
#
# SHARING WITH TEAM:
#   Share this file via a private channel (WhatsApp/Discord).
#   Each team member creates their own .env file locally.
#   The MONGO_URI value is the same for everyone — it points
#   to the shared Atlas cluster.
# =============================================================

# ── MQTT Broker ───────────────────────────────────────────────
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_TOPIC_SENSOR_DATA=smart_agriculture/sensor_data
MQTT_CLIENT_ID=fastapi_backend_01
# Broker auth — must match the ESP32 firmware's MQTT_USERNAME/MQTT_PASSWORD.
# The mosquitto container builds its password file from these at startup.
MQTT_USERNAME=agrisense_esp32
MQTT_PASSWORD=change_me_to_a_strong_password

# ── FastAPI Server ────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=True
APP_TITLE=Smart Agriculture API
APP_VERSION=2.0.0

# ── MongoDB Atlas ─────────────────────────────────────────────
# Get this string from Atlas → your cluster → Connect →
#   "Connect your application" → copy the connection string
# Replace <username>, <password>, <cluster-url> with real values
#
# Atlas format:
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=AgriSense
MONGO_DB_NAME=smart-agriculture-iot
#
# For local development (fallback):
# MONGO_URI=mongodb://localhost:27017
# MONGO_DB_NAME=smart-agriculture-iot

# ── Weather API (OpenWeatherMap) ──────────────────────────────
WEATHER_API_KEY=your_openweathermap_api_key_here
WEATHER_CITY=Mahendranagar
WEATHER_COUNTRY_CODE=NP
WEATHER_CACHE_TTL=600

# ── Machine Learning ──────────────────────────────────────────
ML_MODELS_DIR=ml/saved_models
ML_DATASETS_DIR=ml/datasets
ML_MIN_CONFIDENCE=0.45

# ── Gemini AI (Phase 9 — Bilingual On-Demand Advice) ─────────
# Get your key at: https://aistudio.google.com/app/apikey
# Free tier: 60 req/min, 1500 req/day
# Leave blank to use offline template fallback instead
GEMINI_API_KEY=your_gemini_api_key_here
