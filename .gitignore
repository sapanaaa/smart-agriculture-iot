# =============================================================
# .gitignore — Smart Agriculture Project
# Excludes secrets, build artifacts, IDE files, and OS clutter
# =============================================================

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
.Python

# Virtual environments
venv/
env/
.env/
.venv/
ENV/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/

# ── Environment & Secrets ─────────────────────────────────────
# NEVER commit API keys, passwords, or credentials
.env
.env.local
.env.production
.env.staging
secrets.py
credentials.py

# ── MicroPython / ESP32 ───────────────────────────────────────
# Compiled MicroPython bytecode
*.mpy

# Thonny IDE files
.thonny/
thonny.ini

# ── FastAPI / Backend ─────────────────────────────────────────
# Database files (will use MongoDB — but just in case)
*.db
*.sqlite3
*.sqlite

# Logs
logs/
*.log
*.log.*

# Uploaded files / temp
uploads/
temp/
tmp/

# ── Machine Learning ──────────────────────────────────────────
# Trained model files — large binary files, regenerate with train_models.py
*.pkl
*.pickle
*.joblib
*.h5
*.hdf5
*.onnx
*.pt
*.pth
models/saved/
models/trained/

# ── Phase 10: ML artefacts ARE committed ─────────────────────
# Trained models + training datasets are intentionally tracked so teammates can
# run the project (and CI/CD can deploy to EC2) WITHOUT retraining locally.
# Re-include them despite the generic *.joblib / *.pth / *.pkl ignores above.
!backend/ml/saved_models/
!backend/ml/saved_models/**

# Datasets are tracked too — EXCEPT climate_data.csv: it is ~102 MB (over
# GitHub's 100 MB hard per-file limit) and is unused by the training pipeline.
backend/ml/datasets/climate_data.csv

# Jupyter Notebook checkpoints
.ipynb_checkpoints/
*.ipynb

# ML experiment tracking
mlruns/
wandb/
.dvc/

# ── Node.js / Frontend ────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-error.log
.pnpm-debug.log
yarn.lock

# Next.js build output
.next/
out/

# Build output
dist/
build/
.nuxt/

# ── IDEs & Editors ────────────────────────────────────────────
# VS Code
.vscode/
!.vscode/extensions.json    # keep recommended extensions list

# JetBrains (PyCharm, etc.)
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim / Emacs
*.swp
*.swo
*~
\#*\#

# ── Operating System ──────────────────────────────────────────
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Linux
*~
.fuse_hidden*
.directory

# ── MongoDB ───────────────────────────────────────────────────
data/db/
mongo-data/
*.bson

# ── Docker (for future cloud deployment) ──────────────────────
.docker/
docker-compose.override.yml

# ── Project-specific ──────────────────────────────────────────
# CLAUDE.md is intentionally tracked — shared AI assistant context for the team

# ── Miscellaneous ─────────────────────────────────────────────
# Test coverage
.coverage
htmlcov/
.pytest_cache/
.tox/
coverage/
*.lcov
coverage.xml

# Documentation builds
site/
.claude/

# ── Kiro AI assistant (local workspace — never commit) ────────
.kiro/

# Backup files
*.bak
*.backup
*.orig

# ── Terraform / Infrastructure ────────────────────────────────
# Terraform state files (contain sensitive data)
infrastructure/terraform.tfstate
infrastructure/terraform.tfstate.backup
infrastructure/.terraform/
infrastructure/.terraform.lock.hcl
infrastructure/terraform.tfvars
*.tfstate
*.tfstate.*
.terraform/

# Crash log files
crash.log
crash.*.log

# ── CI/CD & Deployment ────────────────────────────────────────
# SSH keys (NEVER commit private keys)
*.pem
*.key
*.ppk
id_rsa
id_rsa.pub

# GitHub Actions artifacts
.github/workflows/*.log
